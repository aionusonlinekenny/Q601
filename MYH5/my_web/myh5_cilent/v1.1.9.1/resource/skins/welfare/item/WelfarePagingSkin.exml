	</e:Button>
	<e:Scroller id="scroller" width="482" height="85" x="49" scrollPolicyV="off" scrollPolicyH="auto">
		<e:List id="listPaging" x="12" selectedIndex="0" y="0" width="491" itemRendererSkinName="renderer.ActivityTabButtonSkin" itemRenderer="renderer.ActivityTabButton" useVirtualLayout="false">
