<?xml version="1.0" encoding="utf-8"?>
<e:Skin class="item.WelfarePagingSkin" width="580" xmlns:e="http://ns.egret.com/eui" xmlns:w="http://ns.egret.com/wing" xmlns:components="components.*">
	<e:Button id="btnLeft" label="" y="19" x="-3">
