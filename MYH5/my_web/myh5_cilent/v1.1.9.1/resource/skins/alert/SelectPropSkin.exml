<?xml version="1.0" encoding="utf-8"?>
<e:Skin class="dialog.SelectPropSkin" xmlns:e="http://ns.egret.com/eui" xmlns:components="components.*" xmlns:treasure="treasure.*" xmlns:w="http://ns.egret.com/wing" xmlns:ns1="*">
	<e:Image width="528" height="490" source="common_json.img_tips_bg_png" scale9Grid="22,26,21,15"/>
	<e:Button id="btnUse" label="使 用" y="402" skinName="skins.SnapButtonDefaultSkin" width="168" anchorOffsetX="84" anchorOffsetY="28" enabled="true" x="264"/>
	<components:IconButton id="btnClose" source="common_json.btn_close_png" x="493" y="32" anchorOffsetX="25" anchorOffsetY="25"/>
