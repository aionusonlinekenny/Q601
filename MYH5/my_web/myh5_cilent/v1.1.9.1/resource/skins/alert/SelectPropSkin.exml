		<e:Label id="labUseCount" text="1000" y="13" size="20" textAlign="center" width="140" textColor="0xC6B59E" x="165"/>
	</e:Group>
	<e:Scroller width="430" height="146" y="85" horizontalCenter="0" bounces="false" scrollPolicyV="off">
		<e:Group id="gpRewards" touchEnabled="false">
