	<e:Image source="tips_json.img_tips_namebg" y="26" horizontalCenter="0"/>
	<e:Label id="labName" text="" y="33" size="20" textAlign="center" textColor="0xc6b59e" horizontalCenter="0"/>
	<e:Button id="btnRight" label="" y="155" rotation="180.29" x="525">
		<e:skinName>
		<e:Skin states="up,down,disabled" xmlns:w="http://ns.egret.com/wing">
			<e:Image width="100%" height="100%" source="activity_json.img_arrow_leftRight"/>
			<e:Label id="labelDisplay" horizontalCenter="0" verticalCenter="0"/>
		</e:Skin>
		</e:skinName>
	</e:Button>
	<e:Button id="btnLeft" label="" y="105" x="2">
		<e:skinName>
		<e:Skin states="up,down,disabled" xmlns:w="http://ns.egret.com/wing">
			<e:Image width="100%" height="100%" source="activity_json.img_arrow_leftRight"/>
			<e:Label id="labelDisplay" horizontalCenter="0" verticalCenter="0"/>
		</e:Skin>
		</e:skinName>
	</e:Button>
	<e:Label text="使用后获得选中的道具" y="265" size="18" textColor="0x34e22c" x="174"/>
	<e:Label id="labCount" text="数量:10" y="450" size="18" horizontalCenter="0" textColor="0xedc839"/>
	<e:Group width="470" height="45" y="294" anchorOffsetY="0" anchorOffsetX="0" x="29">
		<e:Image y="5" height="40" width="152" source="common_json.img_numbg_png" scale9Grid="17,8,19,8" x="159"/>
		<e:Button id="btnXiao" label="最小" skinName="skins.SnapRedButtonSkin" anchorOffsetX="45" width="90" anchorOffsetY="22" y="21" x="50"/>
		<e:Button id="btnDa" label="最大" y="21" skinName="skins.SnapRedButtonSkin" anchorOffsetX="44" width="90" anchorOffsetY="22" x="419"/>
