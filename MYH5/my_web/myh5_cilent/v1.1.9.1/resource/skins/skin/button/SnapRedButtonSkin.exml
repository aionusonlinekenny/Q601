<?xml version="1.0" encoding="utf-8" ?>
<e:Skin class="skins.SnapRedButtonSkin" states="up,down,disabled" 
        xmlns:e="http://ns.egret.com/eui" xmlns:w="http://ns.egret.com/wing">
    <e:Image alpha.disabled="0.5"
              width="100%" height="100%" source="btn_red_png" source.up="btn_red_png" source.down="btn_red_png" source.disabled="btn_red_png" scale9Grid="16,16,16,16"/>
    <e:Label id="labelDisplay"
             verticalAlign="middle" textAlign="center" size="24" width="100%" height="38" verticalCenter="0" horizontalCenter="0" horizontalCenter.up="1" verticalCenter.up="-3" size.up="24" stroke.up="2" verticalCenter.down="-3" stroke.down="1" size.down="24" strokeColor.down="0x480302" textColor.up="0xffe79b" strokeColor.up="0x320e02" textColor="0xffe79b" textColor.down="0xffe79b" horizontalCenter.down="0"/>
    <e:Image id="iconDisplay" top="0" left="0" includeIn="up,down" source="img_warn_png" />
</e:Skin>