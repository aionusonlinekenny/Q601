<?xml version="1.0" encoding="utf-8"?>
<e:Skin class="dialog.BagSkin" xmlns:e="http://ns.egret.com/eui" xmlns:w="http://ns.egret.com/wing" xmlns:ns1="*" xmlns:components="components.*"  width="600" height="916">
	<e:Group id="item1" y="35" anchorOffsetY="0" width="578" x="11">
		<e:Image source="common_json.img_inbg_png" x="0" y="0" anchorOffsetX="0" width="578" anchorOffsetY="0" height="730" scale9Grid="5,6,18,15"/>
		<e:Image y="727" anchorOffsetX="0" anchorOffsetY="0" horizontalCenter="0" height="105" scale9Grid="80,14,480,6" source="common_implementbar_png"/>

		<e:Scroller id="scroller1" x="16" y="25" anchorOffsetX="0" anchorOffsetY="0" height="670" width="545">
