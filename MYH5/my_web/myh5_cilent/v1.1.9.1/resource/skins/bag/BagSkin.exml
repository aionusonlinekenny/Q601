	<e:Button id="btnEquipt" label="Equipment" x="122" skinName="skins.TabButtonDefaultSkin" icon="img_warn_png" bottom="0"/>
	<e:Button id="btnProp" label="Items" skinName="skins.TabButtonDefaultSkin" icon="img_warn_png" bottom="0" x="240"/>
